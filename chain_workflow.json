{
  "steps": [
    {
      "name": "Get all posts",
      "url": "https://jsonplaceholder.typicode.com/posts",
      "method": "GET",
      "extract": {
        "first_post_id": "$.0.id",
        "first_user_id": "$.0.userId"
      }
    },
    {
      "name": "Get specific post",
      "url": "https://jsonplaceholder.typicode.com/posts/{{first_post_id}}",
      "method": "GET",
      "extract": {
        "post_title": "$.title"
      }
    },
    {
      "name": "Get user who wrote it",
      "url": "https://jsonplaceholder.typicode.com/users/{{first_user_id}}",
      "method": "GET",
      "extract": {
        "username": "$.username"
      }
    },
    {
      "name": "Get that user's todos",
      "url": "https://jsonplaceholder.typicode.com/users/{{first_user_id}}/todos",
      "method": "GET"
    }
  ]
}
